{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "SprintNest",
  "version": "0.4.5",
  "identifier": "com.sprintnest.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "SprintNest",
        "width": 1200,
        "height": 800,
        "resizable": true,
        "fullscreen": false,
        "decorations": false
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": {
          "allow": [
            "$APPDATA/**",
            "$HOME/**"
          ]
        }
      }
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://sn.madplix.de/update/{{target}}/{{current_version}}"
      ],
      "dialog": false,
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDVGQUQ2Mjk2RUQyNzlEMjYKUldRbW5TZnRsbUt0WCtDNzBoV1cwM1FZNmyBbUsyL0dvRW5YOENJd2o3b2RuNGsvQjFJMWdSSVEK"
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": "all",
    "windows": {
      "wix": {
        "language": "de-DE"
      },
      "nsis": {
        "languages": [
          "German"
        ],
        "installMode": "perMachine",
        "installerHooks": "./windows/hooks.nsi"
      }
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
